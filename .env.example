# ====================================================================
#  Passwortmanager Übungs-Demo – Beispiel-Umgebung
#  Kopieren:  cp .env.example .env   und Werte anpassen.
#  WICHTIG: .env enthält Secrets und gehört NICHT ins Git/Frontend.
# ====================================================================

# --- Server ---
PORT=3000
NODE_ENV=production

# Signiert die Session-Cookies. Beliebiger zufälliger String.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=bitte-aendern-zufaelliger-string

# 32-Byte-Schlüssel (64 Hex-Zeichen) für die Verschlüsselung sensibler Daten
# (z.B. TOTP-Secrets) at rest. Pflicht – Server startet ohne ihn nicht.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=00000000000000000000000000000000000000000000000000000000deadbeef

# Pfad zur SQLite-Datei. Im Docker-Container liegt sie auf dem Volume /data.
DB_PATH=./data/app.db

# --- WebAuthn / Passkeys (für localhost) ---
RP_ID=localhost
RP_NAME=Passwortmanager Übungs-Demo
ORIGIN=http://localhost:3000

# --- Cleanup-Job für alte Übungs-Accounts ---
CLEANUP_ENABLED=true
CLEANUP_INTERVAL_MINUTES=60
CLEANUP_MAX_AGE_HOURS=24
